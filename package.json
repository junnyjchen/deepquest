{
  "name": "expo-express-monorepo",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "bash .cozeproj/scripts/dev_run.sh",
    "build": "bash .cozeproj/scripts/prod_build.sh",
    "start": "bash .cozeproj/scripts/prod_run.sh",
    "format:abi": "node scripts/format-abi.mjs",
    "preinstall": "npx only-allow pnpm",
    "lint:client": "pnpm -C client lint",
    "lint:server": "pnpm -C server lint",
    "lint:all": "pnpm -C client lint && pnpm -C server lint"
  },
  "dependencies": {
    "ethers": "^6.16.0"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "overrides": {
      "esbuild": "0.27.2"
    },
    "patchedDependencies": {
      "expo@54.0.33": "patches/expo@54.0.33.patch"
    }
  }
}
