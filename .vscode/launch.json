{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "node",
            "name": "Debug Server",
            "request": "launch",
            "cwd": "${workspaceFolder}/server",
            "runtimeExecutable": "node",
            "runtimeArgs": [
                "--import",
                "tsx",
                "--inspect"
            ],
            "args": [
                "src/index.ts"
            ],
            "env": {
                "NODE_ENV": "development"
            },
            "sourceMaps": true,
            "resolveSourceMapLocations": [
                "${workspaceFolder}/server/src/**"
            ],
            "skipFiles": [
                "<node_internals>/**",
                "**/node_modules/**"
            ]
        },
        {
            "type": "chrome",
            "name": "Debug Client (Chrome)",
            "request": "launch",
            "url": "http://localhost:8081",
            "webRoot": "${workspaceFolder}/client",
            "sourceMaps": true,
            "skipFiles": [
                "<node_internals>/**",
                "**/node_modules/**"
            ]
        },
        {
            "type": "chrome",
            "name": "Open API (dapp/sync)",
            "request": "launch",
            "url": "http://127.0.0.1:9091/api/v1/dapp/sync"
        }
    ]
}