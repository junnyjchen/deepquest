# ============ Server Configuration ============
PORT=9091
NODE_ENV=development

# ============ Supabase Configuration ============
# 你的 Supabase 项目 URL
COZE_SUPABASE_URL=https://your-project-ref.supabase.co

# 你的 Supabase anon/public key (以 eyJ 开头)
COZE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# 你的 Supabase service_role key (以 eyJ 开头)
COZE_SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============ Optional: For Auto Table Creation ============
# Supabase Personal Access Token (可选，用于自动建表)
# 获取方式: Supabase Dashboard -> Access Tokens -> New Token
# SUPABASE_PERSONAL_ACCESS_TOKEN=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============ Frontend Configuration ============
# 前端访问地址
EXPO_PUBLIC_FRONTEND_URL=http://localhost:5000
