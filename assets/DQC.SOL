pragma solidity ^0.8.17;

import "@openzeppelin/contracts/token/ERC721/ERC721.sol";
import "@openzeppelin/contracts/token/ERC721/extensions/ERC721Enumerable.sol";
import "@openzeppelin/contracts/access/Ownable.sol";
import "@openzeppelin/contracts/token/ERC20/IERC20.sol";
import "@openzeppelin/contracts/token/ERC20/utils/SafeERC20.sol";
import "@openzeppelin/contracts/utils/ReentrancyGuard.sol";

// 质押核心合约接口（用于自动设置L等级）
interface IDQMiningStakeCore {
    function setUserLevel(address user, uint8 level) external;
}

// DQMCore合约接口（用于同步等级到DQMCore）
interface IDQMCoreForCard {
    function setUserLevel(address user, uint8 level) external;
}

/**
 * @title DQ Card V2 + 节点DQ/SOL奖励
 * @notice DQC NFT节点卡合约 + 节点奖励分发
 * 
 * 卡片类型:
 * - A卡: 500 USDT
 * - B卡: 1500 USDT
 * - C卡: 5000 USDT
 * 
 * 节点DQ奖励(爆块15%): A卡4% : B卡5% : C卡6% (比例4:5:6)
 * 节点SOL奖励(提现手续费40%): A卡10% : B卡15% : C卡15% (比例10:15:15)
 */
contract DQCard is ERC721Enumerable, Ownable, ReentrancyGuard {
    using SafeERC20 for IERC20;
    
    // ============ USDT合约地址 ============
    address public constant USDT = 0x55d398326f99059fF775485246999027B3197955;
    
    // ============ 卡片类型 ============
    uint256 public constant CARD_A = 1;
    uint256 public constant CARD_B = 2;
    uint256 public constant CARD_C = 3;
    
    // ============ 卡片价格（USDT） ============
    uint256 public constant PRICE_A = 500 * 10**18;   // 500 USDT
    uint256 public constant PRICE_B = 1500 * 10**18;  // 1500 USDT
    uint256 public constant PRICE_C = 5000 * 10**18;  // 5000 USDT
    
    // ============ 发行限制 ============
    uint256 public MAX_A = 1000;
    uint256 public MAX_B = 500;
    uint256 public MAX_C = 100;
    
    // ============ 统计 ============
    uint256 public totalA;
    uint256 public totalB;
    uint256 public totalC;
    
    // ============ 收款地址 ============
    address public treasury;
    
    // ============ 授权地址 ============
    address public miningContract;
    address public adminContract;
    address public stakeContract;  // 质押核心合约（用于自动设置L等级）
    address public coreContract;   // DQMCore合约（用于同步等级）
    
    // ============ 数据映射 ============
    mapping(uint256 => uint256) public cardType;           // tokenId -> 卡片类型
    mapping(address => uint256) public userNodePerformance; // 用户节点业绩
    
    // ============ 节点DQ奖励（新增） ============
    address public DQ_TOKEN;
    uint256[3] public nDQ;                               // DQ累积器: nDQ[idx] = 每卡累计应得DQ
    mapping(address => mapping(uint8 => uint256)) public userNodeDQDebt;
    uint256 public nodeDQRatioA = 4;
    uint256 public nodeDQRatioB = 5;
    uint256 public nodeDQRatioC = 6;
    
    // ============ 节点SOL奖励（新增） ============
    address public SOL_TOKEN;
    uint256[3] public nSOL;                              // SOL累积器: nSOL[idx] = 每卡累计应得SOL
    mapping(address => mapping(uint8 => uint256)) public userNodeSOLDebt;
    uint256 public nodeSOLRatioA = 10;
    uint256 public nodeSOLRatioB = 15;
    uint256 public nodeSOLRatioC = 15;
    
    // ============ 紧急暂停（新增） ============
    bool public paused;
    
    // ============ 事件（旧版保留） ============
    event CardMinted(address indexed to, uint256 indexed tokenId, uint256 cardType);
    event CardPurchased(address indexed buyer, uint256 indexed tokenId, uint256 cardType, uint256 price);
    event NodePerformanceUpdated(address indexed user, uint256 performance);
    event AdminContractUpdated(address indexed adminContract);
    event MaxSupplyUpdated(uint8 cardType, uint256 newMax);
    event TreasuryUpdated(address indexed treasury);
    
    // ============ 事件（新增） ============
    event NodeDQDistributed(uint8 cardType, uint256 amountPerCard);
    event NodeDQClaimed(address indexed user, uint8 cardType, uint256 amount);
    event NodeSOLDistributed(uint8 cardType, uint256 amountPerCard);
    event NodeSOLClaimed(address indexed user, uint8 cardType, uint256 amount);
    event Paused();
    event Unpaused();
    
    // ============ 修饰器（旧版保留） ============
    modifier onlyM() {
        require(msg.sender == stakeContract || msg.sender == owner(), "!m");
        _;
    }
    
    modifier onlyOwnerOrAdmin() {
        require(msg.sender == owner() || msg.sender == adminContract, "!auth");
        _;
    }
    
    modifier whenNotPaused() {
        require(!paused, "paused");
        _;
    }
    
    // ============ 构造函数 ============
    constructor() ERC721("DQ Card", "DQC") Ownable(msg.sender) {}
    
    // ============ 设置函数（旧版保留，不做任何修改） ============
    
    function setTreasury(address _treasury) external onlyOwnerOrAdmin {
        treasury = _treasury;
        emit TreasuryUpdated(_treasury);
    }
    
    function setAdminContract(address _addr) external onlyOwnerOrAdmin {
        adminContract = _addr;
        emit AdminContractUpdated(_addr);
    }
    
    function setMiningContract(address _m) external onlyOwnerOrAdmin {
        miningContract = _m;
    }
    
    function setStakeContract(address _s) external onlyOwnerOrAdmin {
        stakeContract = _s;
    }
    
    function setCoreContract(address _c) external onlyOwnerOrAdmin {
        coreContract = _c;
    }
    
    function setMaxA(uint256 _max) external onlyOwnerOrAdmin {
        MAX_A = _max;
        emit MaxSupplyUpdated(1, _max);
    }
    
    function setMaxB(uint256 _max) external onlyOwnerOrAdmin {
        MAX_B = _max;
        emit MaxSupplyUpdated(2, _max);
    }
    
    function setMaxC(uint256 _max) external onlyOwnerOrAdmin {
        MAX_C = _max;
        emit MaxSupplyUpdated(3, _max);
    }
    
    // ============ 铸造函数（旧版保留，不做任何修改） ============
    
    /**
     * @notice 铸造卡片
     * @param _to 接收地址
     * @param _type 卡片类型 (1=A, 2=B, 3=C)
     */
    function mintByOwner(address _to, uint256 _type) external onlyM {
        _mintCard(_to, _type);
    }
    
    /**
     * @notice 批量铸造卡片
     */
    function mintBatchByOwner(address[] calldata _to, uint256[] calldata _types) external onlyOwnerOrAdmin {
        require(_to.length == _types.length, "length mismatch");
        for (uint256 i = 0; i < _to.length; i++) {
            _mintCard(_to[i], _types[i]);
        }
    }
    
    /**
     * @notice 用户使用USDT购买节点卡
     * @param _type 卡片类型 (1=A, 2=B, 3=C)
     */
    function buyCard(uint256 _type) external {
        require(_type >= CARD_A && _type <= CARD_C, "invalid type");
        require(treasury != address(0), "!treasury");
        
        uint256 price;
        if (_type == CARD_A) {
            require(totalA < MAX_A, "A card sold out");
            totalA++;
            price = PRICE_A;
        } else if (_type == CARD_B) {
            require(totalB < MAX_B, "B card sold out");
            totalB++;
            price = PRICE_B;
        } else {
            require(totalC < MAX_C, "C card sold out");
            totalC++;
            price = PRICE_C;
        }
        
        // 收取USDT
        IERC20(USDT).safeTransferFrom(msg.sender, treasury, price);
        
        // 铸造NFT
        uint256 tokenId = totalSupply() + 1;
        _safeMint(msg.sender, tokenId);
        cardType[tokenId] = _type;
        
        // 更新节点业绩
        userNodePerformance[msg.sender] += price;
        emit NodePerformanceUpdated(msg.sender, userNodePerformance[msg.sender]);
        
        // 自动设置L等级：A卡→S1, B卡→S2, C卡→S3
        if (stakeContract != address(0)) {
            uint8 targetLevel = 0;
            if (_type == CARD_A) targetLevel = 1;  // S1
            else if (_type == CARD_B) targetLevel = 2;  // S2
            else if (_type == CARD_C) targetLevel = 3;  // S3
            
            if (targetLevel > 0) {
                IDQMiningStakeCore(stakeContract).setUserLevel(msg.sender, targetLevel);
                // 同步等级到DQMCore（前端查询展示）
                if (coreContract != address(0)) {
                    IDQMCoreForCard(coreContract).setUserLevel(msg.sender, targetLevel);
                }
            }
        }
        
        emit CardPurchased(msg.sender, tokenId, _type, price);
    }
    
    /**
     * @notice 内部铸造逻辑
     */
    function _mintCard(address _to, uint256 _type) internal {
        require(_type >= CARD_A && _type <= CARD_C, "invalid type");
        
        uint256 price;
        if (_type == CARD_A) {
            require(totalA < MAX_A, "A card sold out");
            totalA++;
            price = PRICE_A;
        } else if (_type == CARD_B) {
            require(totalB < MAX_B, "B card sold out");
            totalB++;
            price = PRICE_B;
        } else {
            require(totalC < MAX_C, "C card sold out");
            totalC++;
            price = PRICE_C;
        }
        
        uint256 tokenId = totalSupply() + 1;
        _safeMint(_to, tokenId);
        cardType[tokenId] = _type;
        
        // 更新节点业绩
        userNodePerformance[_to] += price;
        emit NodePerformanceUpdated(_to, userNodePerformance[_to]);
        
        // 自动设置L等级：A卡→S1, B卡→S2, C卡→S3
        if (stakeContract != address(0)) {
            uint8 targetLevel = 0;
            if (_type == CARD_A) targetLevel = 1;  // S1
            else if (_type == CARD_B) targetLevel = 2;  // S2
            else if (_type == CARD_C) targetLevel = 3;  // S3
            
            if (targetLevel > 0) {
                IDQMiningStakeCore(stakeContract).setUserLevel(_to, targetLevel);
                // 同步等级到DQMCore（前端查询展示）
                if (coreContract != address(0)) {
                    IDQMCoreForCard(coreContract).setUserLevel(_to, targetLevel);
                }
            }
        }
        
        emit CardMinted(_to, tokenId, _type);
    }
    
    // ============ 转移钩子（旧版逻辑保留 + 新增DQ/SOL debt更新） ============
    
    /**
     * @notice 转移钩子(OZ 5.x) - 更新节点业绩 + DQ/SOL debt
     */
    function _update(address to, uint256 tokenId, address auth) internal override returns (address) {
        address from = _ownerOf(tokenId);
        
        // 从原持有者减去业绩 + 结算debt
        if (from != address(0)) {
            uint256 _cardType = cardType[tokenId];
            uint256 price = getCardPrice(_cardType);
            userNodePerformance[from] -= price;
            emit NodePerformanceUpdated(from, userNodePerformance[from]);
            // 新增：结算DQ/SOL debt
            _updateNodeDebt(from, uint8(_cardType));
        }
        
        // 执行转移
        address previousOwner = super._update(to, tokenId, auth);
        
        // 给新持有者增加业绩 + 设置新debt
        if (to != address(0)) {
            uint256 _cardType = cardType[tokenId];
            uint256 price = getCardPrice(_cardType);
            userNodePerformance[to] += price;
            emit NodePerformanceUpdated(to, userNodePerformance[to]);
            // 新增：设置DQ/SOL debt（仅转移时，铸造时在_mintCard后单独处理）
            if (from != address(0)) {
                _updateNodeDebt(to, uint8(_cardType));
            }
        }
        
        return previousOwner;
    }
    
    // ============ 查询函数（旧版保留） ============
    
    /**
     * @notice 获取卡片价格
     */
    function getCardPrice(uint256 _type) public pure returns (uint256) {
        if (_type == CARD_A) return PRICE_A;
        if (_type == CARD_B) return PRICE_B;
        if (_type == CARD_C) return PRICE_C;
        return 0;
    }
    
    /**
     * @notice 获取用户持有的卡片数量
     */
    function getUserCardCount(address _user, uint256 _type) external view returns (uint256) {
        uint256 count;
        uint256 balance = balanceOf(_user);
        for (uint256 i = 0; i < balance; i++) {
            uint256 tokenId = tokenOfOwnerByIndex(_user, i);
            if (cardType[tokenId] == _type) {
                count++;
            }
        }
        return count;
    }
    
    /**
     * @notice 获取用户节点业绩
     */
    function getNodePerformance(address _user) external view returns (uint256) {
        return userNodePerformance[_user];
    }
    
    /**
     * @notice 获取剩余可铸造数量
     */
    function getRemainingSupply() external view returns (uint256 a, uint256 b, uint256 c) {
        a = MAX_A - totalA;
        b = MAX_B - totalB;
        c = MAX_C - totalC;
    }
    
    /**
     * @notice 提取合约资产（管理员）
     */
    function withdrawToken(address _token, address _to, uint256 _amount) external onlyOwnerOrAdmin {
        require(_to != address(0), "!zero");
        if (_token == address(0)) {
            (bool success, ) = payable(_to).call{value: _amount}("");
            require(success, "transfer failed");
        } else {
            IERC20(_token).safeTransfer(_to, _amount);
        }
    }
    
    // ============================================================
    // 以下为新增功能，不修改任何旧版逻辑
    // ============================================================
    
    // ============ 新增：代币地址设置 ============
    
    function setDQToken(address _dq) external onlyOwnerOrAdmin {
        DQ_TOKEN = _dq;
    }
    
    function setSOLToken(address _sol) external onlyOwnerOrAdmin {
        SOL_TOKEN = _sol;
    }
    
    function setMaxSupply(uint256 _maxA, uint256 _maxB, uint256 _maxC) external onlyOwnerOrAdmin {
        MAX_A = _maxA;
        MAX_B = _maxB;
        MAX_C = _maxC;
    }
    
    /// @notice 设置DQ节点分配比例，总和必须=15
    function setNodeDQRatios(uint256 _a, uint256 _b, uint256 _c) external onlyOwnerOrAdmin {
        require(_a + _b + _c == 15, "!15");
        nodeDQRatioA = _a;
        nodeDQRatioB = _b;
        nodeDQRatioC = _c;
    }
    
    /// @notice 设置SOL节点分配比例，总和必须=40
    function setNodeSOLRatios(uint256 _a, uint256 _b, uint256 _c) external onlyOwnerOrAdmin {
        require(_a + _b + _c == 40, "!40");
        nodeSOLRatioA = _a;
        nodeSOLRatioB = _b;
        nodeSOLRatioC = _c;
    }
    
    // ============ 新增：节点DQ奖励分发 ============
    
    /// @notice 管理员手动填入DQ分发数量，先转DQ到本合约再调用
    function distributeNodeDQ(uint256 _amount) external onlyOwnerOrAdmin {
        require(_amount > 0, "0 DQ");
        require(IERC20(DQ_TOKEN).balanceOf(address(this)) >= _amount, "!bal");
        _distributeNodeDQ(_amount);
    }
    
    function _distributeNodeDQ(uint256 _amount) internal {
        if (_amount == 0) return;
        
        uint256 _total = nodeDQRatioA + nodeDQRatioB + nodeDQRatioC;
        uint256 shareA = _amount * nodeDQRatioA / _total;
        uint256 shareB = _amount * nodeDQRatioB / _total;
        uint256 shareC = _amount - shareA - shareB;
        
        if (totalA > 0) nDQ[0] += shareA / totalA;
        if (totalB > 0) nDQ[1] += shareB / totalB;
        if (totalC > 0) nDQ[2] += shareC / totalC;
        
        emit NodeDQDistributed(0, totalA > 0 ? shareA / totalA : 0);
        emit NodeDQDistributed(1, totalB > 0 ? shareB / totalB : 0);
        emit NodeDQDistributed(2, totalC > 0 ? shareC / totalC : 0);
    }
    
    /// @notice 用户一次性领取所有卡类型的节点DQ奖励
    function claimNodeDQReward() external nonReentrant whenNotPaused {
        uint256 totalReward;
        for (uint8 i = 0; i < 3; i++) {
            uint256 count = _getCardCount(msg.sender, i);
            if (count > 0) {
                uint256 pending = count * nDQ[i];
                uint256 reward = pending - userNodeDQDebt[msg.sender][i];
                if (reward > 0) {
                    userNodeDQDebt[msg.sender][i] = pending;
                    totalReward += reward;
                    emit NodeDQClaimed(msg.sender, i, reward);
                }
            }
        }
        require(totalReward > 0, "!reward");
        IERC20(DQ_TOKEN).safeTransfer(msg.sender, totalReward);
    }
    
    /// @notice 查询用户待领取节点DQ奖励(所有卡类型合计)
    function pendingNodeDQ(address _user) external view returns (uint256) {
        uint256 total;
        for (uint8 i = 0; i < 3; i++) {
            uint256 count = _getCardCount(_user, i);
            total += count * nDQ[i] - userNodeDQDebt[_user][i];
        }
        return total;
    }
    
    // ============ 新增：节点SOL奖励分发 ============
    
    /// @notice 管理员手动填入SOL分发数量，先转SOL到本合约再调用
    function distributeNodeSOL(uint256 _amount) external onlyOwnerOrAdmin {
        require(_amount > 0, "0 SOL");
        require(IERC20(SOL_TOKEN).balanceOf(address(this)) >= _amount, "!bal");
        _distributeNodeSOL(_amount);
    }
    
    function _distributeNodeSOL(uint256 _amount) internal {
        if (_amount == 0) return;
        
        uint256 _total = nodeSOLRatioA + nodeSOLRatioB + nodeSOLRatioC;
        uint256 shareA = _amount * nodeSOLRatioA / _total;
        uint256 shareB = _amount * nodeSOLRatioB / _total;
        uint256 shareC = _amount - shareA - shareB;
        
        if (totalA > 0) nSOL[0] += shareA / totalA;
        if (totalB > 0) nSOL[1] += shareB / totalB;
        if (totalC > 0) nSOL[2] += shareC / totalC;
        
        emit NodeSOLDistributed(0, totalA > 0 ? shareA / totalA : 0);
        emit NodeSOLDistributed(1, totalB > 0 ? shareB / totalB : 0);
        emit NodeSOLDistributed(2, totalC > 0 ? shareC / totalC : 0);
    }
    
    /// @notice 用户一次性领取所有卡类型的节点SOL奖励
    function claimNodeSOLReward() external nonReentrant whenNotPaused {
        uint256 totalReward;
        for (uint8 i = 0; i < 3; i++) {
            uint256 count = _getCardCount(msg.sender, i);
            if (count > 0) {
                uint256 pending = count * nSOL[i];
                uint256 reward = pending - userNodeSOLDebt[msg.sender][i];
                if (reward > 0) {
                    userNodeSOLDebt[msg.sender][i] = pending;
                    totalReward += reward;
                    emit NodeSOLClaimed(msg.sender, i, reward);
                }
            }
        }
        require(totalReward > 0, "!reward");
        IERC20(SOL_TOKEN).safeTransfer(msg.sender, totalReward);
    }
    
    /// @notice 查询用户待领取节点SOL奖励(所有卡类型合计)
    function pendingNodeSOL(address _user) external view returns (uint256) {
        uint256 total;
        for (uint8 i = 0; i < 3; i++) {
            uint256 count = _getCardCount(_user, i);
            total += count * nSOL[i] - userNodeSOLDebt[_user][i];
        }
        return total;
    }
    
    // ============ 新增：内部工具 ============
    
    function _getCardCount(address _user, uint8 _type) internal view returns (uint256) {
        uint256 count;
        uint256 balance = balanceOf(_user);
        for (uint256 i = 0; i < balance; i++) {
            uint256 tokenId = tokenOfOwnerByIndex(_user, i);
            if (cardType[tokenId] == _type + 1) {  // _type 0=A, 1=B, 2=C; cardType存1,2,3
                count++;
            }
        }
        return count;
    }
    
    /// @notice 更新用户指定卡类型的DQ/SOL debt
    function _updateNodeDebt(address _user, uint8 _cardType) internal {
        uint8 idx = _cardType - 1;  // cardType 1,2,3 → idx 0,1,2
        uint256 count = _getCardCount(_user, idx);
        userNodeDQDebt[_user][idx] = count * nDQ[idx];
        userNodeSOLDebt[_user][idx] = count * nSOL[idx];
    }
    
    // ============ 新增：查询 ============
    
    function cardCount(uint256 _type) external view returns (uint256) {
        if (_type == 0) return totalA;
        if (_type == 1) return totalB;
        if (_type == 2) return totalC;
        return 0;
    }
    
    /// @notice 查询用户全部待领取节点奖励(DQ+SOL)
    function pendingAllNodeRewards(address _user) external view returns (uint256 dq, uint256 sol) {
        for (uint8 i = 0; i < 3; i++) {
            uint256 count = _getCardCount(_user, i);
            dq += count * nDQ[i] - userNodeDQDebt[_user][i];
            sol += count * nSOL[i] - userNodeSOLDebt[_user][i];
        }
    }
    
    // ============ 新增：紧急操作 ============
    
    function setPaused(bool _paused) external onlyOwnerOrAdmin {
        paused = _paused;
        if (_paused) emit Paused();
        else emit Unpaused();
    }
    
    /// @notice 紧急提取合约中指定代币的全部余额
    function emergencyWithdraw(address _token, address _to) external onlyOwnerOrAdmin {
        require(_to != address(0), "!zero");
        if (_token == address(0)) {
            uint256 bal = address(this).balance;
            if (bal > 0) {
                (bool success, ) = payable(_to).call{value: bal}("");
                require(success, "transfer failed");
            }
        } else {
            uint256 bal = IERC20(_token).balanceOf(address(this));
            if (bal > 0) {
                IERC20(_token).safeTransfer(_to, bal);
            }
        }
    }
    
    // ============ 接收BNB(备用) ============
    receive() external payable {}
}
