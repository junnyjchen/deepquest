pragma solidity ^0.8.17;
import "@openzeppelin/contracts/token/ERC721/ERC721.sol";
import "@openzeppelin/contracts/token/ERC721/extensions/ERC721Enumerable.sol";
import "@openzeppelin/contracts/access/Ownable.sol";
import "@openzeppelin/contracts/utils/structs/EnumerableSet.sol";
contract DQCard is ERC721Enumerable, Ownable {
    using EnumerableSet for EnumerableSet.UintSet;
    uint256 public constant CARD_A = 1;
    uint256 public constant CARD_B = 2;
    uint256 public constant CARD_C = 3;
    uint256 public constant PRICE_A = 500 ether;
    uint256 public constant PRICE_B = 1500 ether;
    uint256 public constant PRICE_C = 5000 ether;
    uint256 public totalA;
    uint256 public totalB;
    uint256 public totalC;
    uint256 public MAX_A = 1000;
    uint256 public MAX_B = 500;
    uint256 public MAX_C = 100;
    mapping(address => uint256) public userNodePerformance;      
    address public miningContract;
    mapping(uint256 => uint256) public cardType;
    mapping(address => EnumerableSet.UintSet) private _holderTokens;
    modifier onlyM() {
        require(msg.sender == miningContract, "!auth");
        _;
    }
    event NodePerformanceUpdated(address indexed user, uint256 performance);
    constructor() ERC721("DQ Card", "DQC") {}
    function setMaxA(uint256 _max) external onlyOwner { MAX_A = _max; }
    function setMaxB(uint256 _max) external onlyOwner { MAX_B = _max; }
    function setMaxC(uint256 _max) external onlyOwner { MAX_C = _max; }
    function setMiningContract(address _m) external onlyOwner {
        miningContract = _m;
    }
    function mintByOwner(address to, uint256 _type) external {
        require(msg.sender == owner() || msg.sender == miningContract, "!auth");
        _mintCard(to, _type);
    }
    function mintBatchByOwner(address[] calldata to, uint256[] calldata _types) external onlyOwner {
        require(to.length == _types.length, "length mismatch");
        for (uint i = 0; i < to.length; i++) {
            _mintCard(to[i], _types[i]);
        }
    }
    function _mintCard(address to, uint256 _type) internal {
        require(_type >= CARD_A && _type <= CARD_C, "invalid type");
        uint256 price;
        if (_type == CARD_A) {
            require(totalA < MAX_A, "A card sold out");
            totalA++;
            price = PRICE_A;
        } else if (_type == CARD_B) {
            require(totalB < MAX_B, "B card sold out");
            totalB++;
            price = PRICE_B;
        } else {
            require(totalC < MAX_C, "C card sold out");
            totalC++;
            price = PRICE_C;
        }
        uint256 tokenId = totalSupply() + 1;
        _safeMint(to, tokenId);
        cardType[tokenId] = _type;
        _holderTokens[to].add(tokenId);
        userNodePerformance[to] += price;
        emit NodePerformanceUpdated(to, userNodePerformance[to]);
    }
    function _beforeTokenTransfer(
        address from,
        address to,
        uint256 firstTokenId,
        uint256 batchSize
    ) internal override {
        super._beforeTokenTransfer(from, to, firstTokenId, batchSize);
        if (batchSize > 1) {
            revert("ERC721Enumerable: consecutive transfers not supported");
        }
        if (from != address(0)) {
            _holderTokens[from].remove(firstTokenId);
            uint256 price = getCardPrice(cardType[firstTokenId]);
            userNodePerformance[from] -= price;
            emit NodePerformanceUpdated(from, userNodePerformance[from]);
        }
        if (to != address(0)) {
            _holderTokens[to].add(firstTokenId);
            uint256 price = getCardPrice(cardType[firstTokenId]);
            userNodePerformance[to] += price;
            emit NodePerformanceUpdated(to, userNodePerformance[to]);
        }
    }
    function getCardPrice(uint256 _type) public pure returns (uint256) {
        if (_type == CARD_A) return PRICE_A;
        if (_type == CARD_B) return PRICE_B;
        return PRICE_C;
    }
    function getUserNodePerformance(address _user) external view returns (uint256) {
        return userNodePerformance[_user];
    }
    function updateNodePerformance(address _user, uint256 _performance) external onlyOwner {
        userNodePerformance[_user] = _performance;
        emit NodePerformanceUpdated(_user, _performance);
    }
}